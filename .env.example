# Do not commit real credentials. Use local .env.local / deployment secrets.

# Authentication
ADMIN_PASSWORD=change-me
USER_PASSWORD=change-me
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# Server-side Supabase PostgreSQL
SUPABASE_DATABASE_URL=postgresql://user:password@db.your-project.supabase.co:5432/postgres
# Optional alias when envs are exported via Vercel CLI
SUPABASE_DB_URL=

# Supabase REST
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Security webhooks (server-side)
SECURITY_WEBHOOK_URL=
SECURITY_WEBHOOK_TEST_URL=

# Optional public display in admin settings (only set if intentionally public)
NEXT_PUBLIC_SECURITY_WEBHOOK_URL=
NEXT_PUBLIC_SECURITY_WEBHOOK_TEST_URL=

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-PYTZQ0NEPP

# Optional public demo mode (read-only UI + API write lock)
DEMO_READ_ONLY=false
NEXT_PUBLIC_DEMO_READ_ONLY=false
# Optional: force demo credentials only for login (also auto-enabled when DEMO_READ_ONLY=true)
DEMO_CREDENTIALS_ONLY=false
DEMO_ADMIN_PASSWORD=
DEMO_USER_PASSWORD=
# Public signup link for demo credentials + basis license popup on login page
NEXT_PUBLIC_DEMO_SIGNUP_URL=
NEXT_PUBLIC_LICENSE_SIGNUP_URL=

# Optional legacy fallback hash (SHA-256) for one bootstrap code
# BASIC_LICENSE_HASH=
# Optional: allow demo credentials to bypass Supabase license check
LICENSE_ALLOW_DEMO_BYPASS=false

# n8n Premium Activation (optional legacy fallback hash)
N8N_ACTIVATION_HASH=
